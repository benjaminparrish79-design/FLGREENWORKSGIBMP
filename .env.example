# FL-GreenGuard Environment Variables Template
# Copy this file to .env and fill in your real keys.
# DO NOT commit your real .env file to GitHub.

# --- RevenueCat ---
# Get this from: https://app.revenuecat.com/
EXPO_PUBLIC_REVENUECAT_KEY=your_revenuecat_public_api_key_here

# --- Supabase ---
# Get these from: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Database (PostgreSQL via Supabase) ---
# Connection string for Drizzle ORM (server-side only, never expose in client bundle)
# Get from: https://app.supabase.com/project/_/settings/database → Connection string → URI
DATABASE_URL=postgresql://postgres:password@db.your-project-id.supabase.co:5432/postgres

# --- OpenWeatherMap ---
# Get a free key from: https://openweathermap.org/api
# EXPO_PUBLIC_ prefix makes it available in both the Expo client and the Node server.
EXPO_PUBLIC_OPENWEATHER_API_KEY=your_openweathermap_api_key_here
